# ForexMind Environment Variables
# Copy this to .env and fill in your values

# ── MT5 Credentials (from your broker demo email) ─────────────────────
MT5_LOGIN=your_mt5_login_number
MT5_PASSWORD=your_mt5_password
MT5_SERVER=MetaQuotes-Demo

# ── Groq API (free at console.groq.com) ───────────────────────────────
GROQ_API_KEY=************

# ── Alpha Vantage (free at alphavantage.co) ───────────────────────────
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# ── NewsAPI (free at newsapi.org) ─────────────────────────────────────
NEWS_API_KEY=your_newsapi_key

# ── Telegram Bot (optional but recommended) ───────────────────────────
# Step 1: Message @BotFather on Telegram → /newbot → get token
# Step 2: Message @userinfobot on Telegram → get your chat_id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
